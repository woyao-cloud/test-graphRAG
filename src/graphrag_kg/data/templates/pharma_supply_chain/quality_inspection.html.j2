</tr>
<tr>
  <td>{{ by_type['drug'][1].name }}</td>
  <td>{{ by_type['pharmaceutical_company'][0].name }}</td>
  <td>20241102C</td>
  <td>{{ by_type['hospital'][0].name }}药房</td>
  <td>含量、溶出度、有关物质</td>
  <td class="pass">合格</td>
</tr>
<tr>
  <td>{{ by_type['drug'][2].name }}</td>
  <td>{{ by_type['pharmaceutical_company'][1].name }}</td>
  <td>20241020D</td>
  <td>{{ by_type['hospital'][1].name }}药房</td>
  <td>含量、纯度、内毒素</td>
  <td class="pass">合格</td>
</tr>
<tr>
  <td>{{ by_type['drug'][3].name }}</td>
  <td>{{ by_type['pharmaceutical_company'][1].name }}</td>
