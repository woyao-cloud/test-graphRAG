# === LLM Configuration ===
# Chat model for extraction and query answering
GRAPHRAG_CHAT_MODEL=llama3.2
GRAPHRAG_CHAT_MODEL_PROVIDER=openai
GRAPHRAG_API_BASE=http://localhost:11434

# Embedding model — set to any embedding model available in Ollama (e.g. nomic-embed-text, bge-m3)
GRAPHRAG_EMBEDDING_MODEL=nomic-embed-text
GRAPHRAG_EMBEDDING_MODEL_PROVIDER=ollama
GRAPHRAG_API_BASE_EMBED=http://localhost:11434

# API key not needed for local Ollama, but must be set (non-empty) for graphrag library
GRAPHRAG_API_KEY=local-ollama

# === Neo4j Configuration ===
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j

# === Optional: Azure OpenAI ===
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_API_VERSION=2024-02-15-preview

# === Optional: Anthropic ===
# ANTHROPIC_API_KEY=

# === Optional: Local Ollama ===
# Uncomment and adjust for fully local operation with Ollama.
# Make sure the models are pulled first: ollama pull llama3.2 && ollama pull nomic-embed-text
# GRAPHRAG_API_KEY=not-needed
# GRAPHRAG_CHAT_MODEL=llama3.2
# GRAPHRAG_CHAT_MODEL_PROVIDER=openai
# GRAPHRAG_API_BASE=http://localhost:11434
# GRAPHRAG_EMBEDDING_MODEL=nomic-embed-text
# GRAPHRAG_EMBEDDING_MODEL_PROVIDER=ollama
# GRAPHRAG_API_BASE_EMBED=http://localhost:11434
